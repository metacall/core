# =============================================================================
# 7. MetaCall internals — allocated during metacall_initialize(), not freed
#    because EXPECT_DEATH subprocess crashes before metacall_destroy() runs
# =============================================================================
{
   metacall_init_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:metacall_initialize
}

{
   metacall_init_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   fun:metacall_initialize
}

{
   metacall_log_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:metacall_log
}

{
   metacall_link_init_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:metacall_link_initialize
}

