# Valgrind suppression file for metacall-backtrace-plugin-test
#
# This test deliberately triggers a segfault (via badass_function writing to
# address 0x2a) to exercise the backtrace plugin's signal handler. The
# EXPECT_DEATH subprocess that crashes never calls metacall_destroy(), so all
# resources allocated during metacall_initialize() appear as "still reachable"
# or "possibly lost" at process exit.
#
# Additionally, third-party singletons (OpenSSL, libcurl, GTest, glibc regex,
# debuginfod/libdw) allocate global state that is never freed by design.

# =============================================================================
# 1. Intentional Invalid Pointer Write in badass_function
# =============================================================================
{
   badass_function_intentional_ipw
   Memcheck:Addr1
   fun:*badass_function*
}

# =============================================================================
# 2. GTest internals — singleton allocations that persist until process exit
# =============================================================================
{
   gtest_unittest_impl_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*testing*internal*UnitTestImpl*
}

{
   gtest_make_and_register
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*testing*internal*MakeAndRegisterTestInfo*
}

{
   gtest_test_suite_add
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*testing*TestSuite*AddTestInfo*
}

{
   gtest_test_event_repeater
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*testing*internal*TestEventRepeater*
}

{
   gtest_os_stack_trace
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*testing*internal*UnitTestImpl*os_stack_trace_getter*
}

{
   gtest_global_init
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:*GLOBAL*sub*I*badass*
}

# =============================================================================
# 3. GTest regex (POSIX regex via glibc) — from RE::Init
# =============================================================================
{
   gtest_regex_init_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:regcomp
   ...
   fun:*testing*internal*RE*Init*
}

